-- ~/.conky/cpu_temp.lua

function conky_pkg_temp()
    local handle = io.popen("sensors | grep 'Package id 0' | awk '{print $4}'")
    local result = handle:read("*a")
    handle:close()
    return result:gsub("\n", "")
end

