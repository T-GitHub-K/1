conky.config = {
    alignment = 'top_left',
    background = false,
    border_width = 0,
    cpu_avg_samples = 2,
    default_color = 'aaaaaa',
    default_outline_color = 'white',
    default_shade_color = 'white',
    double_buffer = true,
    draw_borders = false,
    draw_graph_borders = true,
    draw_outline = false,
    draw_shades = false,
    use_xft = true,
    font = 'Monospace:size=11',
    gap_x = 10,
    gap_y = 5,
    minimum_height = 5,
    minimum_width = 5,
    net_avg_samples = 2,
    out_to_console = false,
    out_to_stderr = false,
    extra_newline = false,
    own_window = true,
    own_window_class = 'Conky',
    own_window_type = 'dock',
    own_window_transparent = false,
    own_window_argb_visual = true,
    own_window_argb_value = 0,
    
    own_window_hints = 'undecorated,below,sticky,skip_taskbar,skip_pager',
    stippled_borders = 0,
    update_interval = 1.0,
    uppercase = false,
    use_spacer = 'none',
    show_graph_scale = false,
    show_graph_range = false,

-- CPU温度、負荷色を取得する関数
   lua_load = '/etc/conky/cpu_uty.lua',
}

conky.text = [[

${color ffa500}${alignc}${execi 3600 neofetch | grep 'Host' | cut -c 36-52}
${color lightgreen} OS   $color ${sysname} ${kernel}
${color lightgreen}      $color ${execi 3600 neofetch | grep 'OS' | cut -c 35-56}
${color lightgreen}      $color ${execi 3600 neofetch | grep 'DE' | cut -c 35-48}
${color ffa500}${alignc}CPU
#
${color lightgreen}${execi 3600 neofetch | grep 'CPU' | cut -c 35-64}${alignr}${lua_parse cpu_fan_color}${lua cpu_fan} RPM
#
${color lightgreen}      $color ${freq_g 1}GHz  ${lua pkg_temp}   ${alignr}${cpu cpu1}% ${lua_parse cpu_bar_color cpu1}${cpubar cpu1 12,70}
${color lightgreen}      $color ${freq_g 2}GHz  ${lua core0_temp} ${alignr}${cpu cpu2}% ${lua_parse cpu_bar_color cpu2}${cpubar cpu2 12,70}
${color lightgreen}      $color ${freq_g 3}GHz  ${lua core1_temp} ${alignr}${cpu cpu3}% ${lua_parse cpu_bar_color cpu3}${cpubar cpu3 12,70}
${color lightgreen}      $color ${freq_g 4}GHz  ${lua cpu_temp}   ${alignr}${cpu cpu4}% ${lua_parse cpu_bar_color cpu4}${cpubar cpu4 12,70}
#
${color ffa500}${alignc}MEMORY
${color lightgreen} Ram  ${color} $mem / $memmax  ${alignr}$memperc% ${lua_parse mem_color}${membar 12,70}
${color lightgreen} Swap ${color} $swap / $swapmax  ${alignr}$swapperc% ${color 444444}${swapbar 12,70}
${color ffa500}${alignc}DISK
${color lightgreen} root    $color${fs_used /} / ${fs_size /}${alignr}${fs_used_perc /}% ${color 444444}${fs_bar 12,70 /}
${color lightgreen} Read   $color${alignr}${diskio_read /dev/sda}   ${diskiograph_read 18,100 444444 444444}
${color lightgreen} Write  $color${alignr}${diskio_write /dev/sda}   ${diskiograph_write 18,100 444444 444444}
${color ffa500}${alignc}NETWORK
${color lightgreen} ssid  ${color}${wireless_essid wlp1s0}${alignr}${color} ${addr wlp1s0}
${color lightgreen} Bitrate ${color} ${wireless_bitrate wlp1s0}${alignr}${wireless_link_qual_perc wlp1s0}% ${color 444444}${wireless_link_bar 12,70 wlp1s0}
${color lightgreen} Up   ${color}${alignr}${upspeed wlp1s0}${color}  ${totalup wlp1s0}  ${upspeedgraph wlp1s0 18,100 444444 444444}
${color lightgreen} Down ${color}${alignr}${downspeed wlp1s0}${color}   ${totaldown wlp1s0}  ${downspeedgraph wlp1s0 18,100 444444 444444}
${color ffa500}${alignc}PROCESS
${color lightgreen} Name                PID     CPU     MEM
${color}${alignr}${top name 1} ${top pid 1} ${top cpu 1}% ${top mem 1}%
${color}${alignr}${top name 2} ${top pid 2} ${top cpu 2}% ${top mem 2}%
${color}${alignr}${top name 3} ${top pid 3} ${top cpu 3}% ${top mem 3}%
${color}${alignr}${top name 4} ${top pid 4} ${top cpu 4}% ${top mem 4}%
${color}${alignr}${top name 5} ${top pid 5} ${top cpu 5}% ${top mem 5}%

${color lightgreen}$color ${font Monospace:size=16}${time %Y-%m-%d [%a]}${alignr}${time %H:%M}${font Monospace:size=12}${time :%S}
#${color lightgreen}$color ${font Monospace:size=16}${time %Y-%m-%d [%a]}${alignr}${time %H:%M}${time :%S}
#${color bb6100} ${font Monospace:size=9}Ver Conky/custom: ${conky_version}/1.13.02${alignr}${uptime}${font}
]]
