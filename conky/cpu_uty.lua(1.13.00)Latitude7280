function conky_cpu_bar_color(cpu_name)
    local cpu = tonumber(conky_parse("${cpu " .. cpu_name .. "}")) or 0

    if cpu <= 50 then
        return "${color 90ee90}"   -- 緑
    elseif cpu <= 80 then
        return "${color ffa500}"   -- 黄色
    else
        return "${color ff0000}"   -- 赤
    end
end

function conky_cpu_fan_color()
    local handle = io.popen("sensors | grep 'Processor Fan' | awk '{print $3}'")

    if not handle then
        return "${color 444444}"
    end

    local result = handle:read("*a")
    handle:close()

    local fan = tonumber(result:match("^%s*(.-)%s*$")) or 0

    if fan <= 3000 then
        return "${color 444444}"   -- 灰
    elseif fan <= 8000 then
        return "${color ffa500}"   -- 黄色
    else
        return "${color ff0000}"   -- 赤
    end
end

