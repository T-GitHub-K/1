-- /etc/conky/cpu_uty.lua

function conky_cpu_fan()
    local handle = io.popen("sensors | grep 'fan1' | awk '{print $2}'")
    local result = handle:read("*a")
    handle:close()
    return result:gsub("\n", "")
end

